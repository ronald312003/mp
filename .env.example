# ============================================================
#  Maison Privée — Variables de entorno
#  Copia este archivo a .env.local para desarrollo,
#  y define las mismas variables en Vercel para producción.
# ============================================================

# --- Base de datos Neon (Postgres) ---
# En Neon: Project → Connection Details → "Connection string" (Pooled).
# Debe incluir ?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"

# --- Tipo de cambio (Kambista) ---
# Margen que se SUMA al valor de venta del dólar de Kambista.
# El usuario pidió +0.10. Si algún día quieres cambiarlo, edítalo aquí.
EXCHANGE_MARKUP="0.10"

# Valor de respaldo del tipo de cambio (soles por dólar, ya con el +0.10),
# usado sólo si Kambista no responde en el momento del scraping.
EXCHANGE_FALLBACK_PEN="3.51"

# --- Clasificación inteligente (IA) ---
# Se usa para clasificar productos en colecciones (outfits/estilos) de forma
# inteligente durante el scraping y al crear productos en /admin.
# Si no la defines, se usa la clasificación por reglas (sin IA).
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.4-mini"

# --- Recomendaciones e imágenes editoriales (Gemini) ---
# Gemini elige complementos del catálogo y, opcionalmente, genera imágenes.
# Nunca guardes aquí una clave real: usa .env.local o variables de Vercel.
GEMINI_API_KEY=""
# "aistudio" (por defecto) o "vertex". Usa vertex solo si habilitaste
# aiplatform.googleapis.com en el proyecto de Google Cloud.
GEMINI_API_PROVIDER="aistudio"
GEMINI_IMG_LIMIT="0"

# --- Panel de administrador (/admin) ---
# Contraseña para iniciar sesión en /admin y gestionar productos.
ADMIN_PASSWORD="cambia-esta-clave"

# Cadena larga y aleatoria para firmar la cookie de sesión del admin.
# Genera una con:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET="pon-aqui-una-cadena-larga-aleatoria"

# --- Opcional: revalidación / build ---
# Token propio para proteger el endpoint /api/exchange si lo llamas desde un cron.
REVALIDATE_TOKEN=""
